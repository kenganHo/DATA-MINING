        "import pandas as pd\n",
        "\n",
        "df = pd.read_csv(\"https://raw.githubusercontent.com/lovedlim/bigdata_analyst_cert_v2/main/part4/ch9/crime.csv\")\n",
        "\n",
        "cond1 = df[\"구분\"] == \"발생건수\"\n",
        "cond2 = df[\"구분\"] == \"검거건수\"\n",
        "df1 = df[cond1].iloc[:, 2:].reset_index(drop=True)\n",
        "df2 = df[cond2].iloc[:, 2:].reset_index(drop=True)\n",
        "\n",
        "df3 = df2 / df1\n",
        "\n",
        "listbox = df3.idxmax(axis=1)\n",
        "\n",
        "result = 0\n",
        "for index, item in enumerate(listbox):\n",
        "    result += df2.loc[index, item]\n",
        "\n",
        "print(result)"
