        "import pandas as pd\n",
        "\n",
        "df = pd.read_csv(\"https://raw.githubusercontent.com/lovedlim/bigdata_analyst_cert/main/part4/ch7/air_quality.csv\")\n",
        "\n",
        "Q1 = df['CO2'].quantile(0.25)\n",
        "Q3 = df['CO2'].quantile(0.75)\n",
        "IQR = Q3 - Q1\n",
        "\n",
        "upper = Q3 + 1.5 * IQR\n",
        "lower = Q1 - 1.5 * IQR\n",
        "\n",
        "outliers = df[(df['CO2'] < lower) | (df['CO2'] > upper)]\n",
        "\n",
        "print(len(outliers))"
